# Copy on app EC2: cp scripts/deploy/env.example run/env.sh && chmod 600 run/env.sh
# 현재 DB: H2 파일 (기본값). application-prod.yml 기본값과 동일하면 아래 DB 변수는 생략 가능.

# (선택) H2 경로·계정 덮어쓰기
# export SPRING_DATASOURCE_URL="jdbc:h2:file:./data/dontdelay-db;DB_CLOSE_DELAY=-1"
# export SPRING_DATASOURCE_DRIVER_CLASS_NAME="org.h2.Driver"
# export SPRING_DATASOURCE_USERNAME="sa"
# export SPRING_DATASOURCE_PASSWORD=""
# export SPRING_JPA_DATABASE_PLATFORM="org.hibernate.dialect.H2Dialect"

# Postgres + pgvector 전환 시 (docs/DATABASE_EC2.md)
# export SPRING_DATASOURCE_URL="jdbc:postgresql://<DB_PRIVATE_IP>:5432/dontdelay"
# export SPRING_DATASOURCE_DRIVER_CLASS_NAME="org.postgresql.Driver"
# export SPRING_DATASOURCE_USERNAME="dontdelay_app"
# export SPRING_DATASOURCE_PASSWORD="change-me"
# export SPRING_JPA_DATABASE_PLATFORM="org.hibernate.dialect.PostgreSQLDialect"

# OpenAI (임베딩)
export OPENAI_API_KEY="sk-..."
export OPENAI_EMBEDDING_MODEL="text-embedding-3-small"

# Gemini (AI 코치)
export GEMINI_API_KEY="..."
export GEMINI_MODEL="gemini-2.0-flash"

# Upstage Document OCR (스캔 PDF fallback)
export UPSTAGE_API_KEY="up_..."
export OCR_ENABLED="true"
