# Copy on app EC2: cp scripts/deploy/env.example run/env.sh && chmod 600 run/env.sh
# Postgres enabled when SPRING_DATASOURCE_URL is set (restart.sh sources this file).

export SPRING_DATASOURCE_URL="jdbc:postgresql://<DB_PRIVATE_IP>:5432/dontdelay"
export SPRING_DATASOURCE_USERNAME="dontdelay_app"
export SPRING_DATASOURCE_PASSWORD="change-me"
export SPRING_JPA_DATABASE_PLATFORM="org.hibernate.dialect.PostgreSQLDialect"
